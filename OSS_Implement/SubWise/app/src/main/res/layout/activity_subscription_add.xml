<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#E8F2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서비스명"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editServiceName"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="서비스명"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="월 결제 금액"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editPrice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="₩"
            android:inputType="number"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="결제일 선택"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/editBillingDate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="결제일"
            android:focusable="false"
            android:padding="8dp"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar" />

        <TextView
            android:id="@+id/txtNextPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="다음달 결제 예정일: -"
            android:layout_marginTop="8dp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="카테고리 선택"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnOtt"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="OTT"
                android:layout_margin="4dp"
                android:backgroundTint="#6C63FF"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnLife"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="생활"
                android:layout_margin="4dp"
                android:backgroundTint="#6FCF97"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnBook"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="도서"
                android:layout_margin="4dp"
                android:backgroundTint="#F2C94C"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnGame"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="게임"
                android:layout_margin="4dp"
                android:backgroundTint="#BB6BD9"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/chkEssential"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="이 구독은 필수인가요? (체크 시 다이어트 시뮬레이션에서 제외됩니다.)"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnParty"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="다른 사람과 공유 중인가요? (파티 생성)"
            android:layout_marginTop="16dp"
            android:backgroundTint="#4A90E2"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnComplete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="구독 추가 완료"
            android:layout_marginTop="16dp"
            android:backgroundTint="#003399"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>
